# Optional overrides — all values have defaults in config.py
# Create a .env file in this directory to override any of these

# NOAA weather API contact info (default: ["Automation Suite", "contact@example.com"])
# WEATHER_API_KEY=your_app_name,your_contact_email

# Sports API key (default: "demo_key")
# SPORTS_API_KEY=your_sports_api_key

# APP_NAME=Automation Suite

# Database connection URL (default: SQLite at backend/database/automation.db)
# DATABASE_URL=sqlite:///path/to/your/database.db

# DEFAULT_CITY=Seattle

# Scheduler interval in minutes (default: 30)
# AUTOMATION_CADENCE=30

# CORS allowed origins (default: ["*"] allows all)
# In production, set to your frontend URL(s)
# CORS_ORIGINS=["http://your-ec2-ip:3000","https://your-domain.com"]
